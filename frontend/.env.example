# Hermes Mission Control — Frontend Environment Variables
# Copy this file to .env and adjust for your deployment.
# Never commit .env to version control.

# Base URL for the FastAPI backend REST API.
# In production (behind NGINX), leave as /api/v1 to use the proxy.
# For local Vite dev server talking directly to uvicorn: http://localhost:8000/api/v1
VITE_API_BASE_URL=/api/v1

# WebSocket URL for the live telemetry stream.
# Use wss:// when TLS/HTTPS is enabled.
VITE_WS_BASE_URL=ws://localhost:8000/ws/telemetry

# WebSocket URL for the PTY (embedded terminal) endpoint.
VITE_PTY_WS_URL=ws://localhost:8000/api/pty
