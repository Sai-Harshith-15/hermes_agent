# Hermes Mission Control — Backend Environment Variables
# Copy this file to .env and adjust for your deployment.
# Never commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────────
PROJECT_NAME="Hermes Mission Control"

# ── Database ───────────────────────────────────────────────────────────────────
# Default: SQLite stored in the Hermes home directory.
# Override HERMES_DIR to change the location of hermes_state.db.
# Example for Docker: HERMES_DIR=/data/hermes
HERMES_DIR=~/.hermes

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_a_secure_random_key_in_production
ALGORITHM=HS256

# Token lifetime in minutes. 1440 = 24 hours.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Vault Encryption ───────────────────────────────────────────────────────────
# 32-byte URL-safe base64 key used by the Fernet cipher to encrypt stored API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=ZGVmYXVsdF9tYXN0ZXJfa2V5X2NoYW5nZV9tZV9ub3c=
